# Web app host port exposed by Docker Compose.
LEGACY_WEB_PORT=3000

# Optional server-defined default Redis connection.
# For an external Redis instance:
# LEGACY_DEFAULT_REDIS_URL=redis://default:redispw@example.com:6379/0
LEGACY_DEFAULT_REDIS_URL=

# For the optional Compose demo Redis profile, use:
# LEGACY_DEFAULT_REDIS_URL=redis://demo-redis:6379

# Used to sign the session cookie name/value boundary in future versions.
# V1 still stores temporary connection credentials in process memory.
LEGACY_SESSION_SECRET=change-me-in-production
